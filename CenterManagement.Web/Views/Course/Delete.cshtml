@model CenterManagement.Domain.Entities.Course

@{
    ViewData["Title"] = "Archive Course";
}

<div class="max-w-xl mx-auto mt-12">
    <div class="bg-surface-container-lowest rounded-2xl shadow-lg border border-outline-variant overflow-hidden">
        <div class="p-8 text-center">
            <div class="w-16 h-16 bg-error-container text-error rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-3xl">warning</span>
            </div>
            <h2 class="text-headline-md font-headline-md text-on-surface mb-2">Archive Course?</h2>
            <p class="text-body-md text-on-surface-variant mb-6">
                Are you sure you want to archive <strong>@Model.Name</strong>? This action will mark it as deleted and hide it from all primary views. You cannot undo this immediately.
            </p>
            
            <div class="bg-surface-container-low rounded-xl p-4 mb-8 text-left border border-outline-variant">
                <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Course Details</p>
                <p class="text-body-md text-on-surface font-medium">@Model.Name</p>
                <p class="text-body-sm text-on-surface-variant">Price: @Model.Price.ToString("C")</p>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex gap-4">
                @Html.AntiForgeryToken()
                <a href="javascript:history.back()" class="flex-1 py-3.5 rounded-xl border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors">
                    Cancel
                </a>
                <button type="submit" class="flex-1 py-3.5 rounded-xl bg-error text-white font-label-md shadow-md hover:bg-error/90 transition-all">
                    Archive Course
                </button>
            </form>
        </div>
    </div>
</div>
