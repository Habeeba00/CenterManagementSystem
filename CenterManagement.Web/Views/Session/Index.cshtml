@model List<SessionListItemDto>

@{
    ViewData["Title"] = "Sessions Calendar";
    var isAdmin = User.IsInRole("Admin");
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }
</style>

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-stack-md mb-gutter">
    <div class="space-y-1">
        <h3 class="font-headline-md text-headline-md text-on-surface">Sessions Calendar</h3>
        <p class="text-body-sm text-outline">Track daily classes, manage schedules, and monitor attendance.</p>
    </div>
    @if (isAdmin)
    {
        <div class="flex items-center gap-3">
            <a asp-action="Create" class="flex items-center gap-2 px-5 py-2.5 bg-primary-container text-white font-label-md text-label-md rounded-lg shadow-md hover:opacity-90 transition-all active:scale-95">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Schedule Session
            </a>
        </div>
    }
</div>

<form method="get" asp-action="Index" class="bg-surface-container-lowest p-stack-md rounded-xl shadow-sm border border-outline-variant flex flex-wrap gap-4 items-end mb-gutter">
    <div class="w-48">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Date</label>
        <input type="date" name="date" value="@ViewData["CurrentDate"]" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm outline-none" />
    </div>
    <div class="w-48">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Group</label>
        <select name="groupId" asp-items="ViewBag.GroupSelectList" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm outline-none">
            <option value="">All Groups</option>
        </select>
    </div>
    <button type="submit" class="h-10 px-4 bg-surface-container hover:bg-surface-container-high text-on-surface-variant rounded-lg transition-colors">
        <span class="material-symbols-outlined">filter_list</span>
    </button>
    <a asp-action="Index" class="h-10 px-4 flex items-center bg-surface-container hover:bg-surface-container-high text-on-surface-variant rounded-lg transition-colors">
        Clear
    </a>
</form>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        @TempData["Success"]
    </div>
}

<div class="bg-surface-container-lowest rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant overflow-hidden mb-gutter">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant">
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Date & Time</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Group</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Instructor</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Attendance</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (Model.Any())
                {
                    @foreach (var s in Model)
                    {
                        var isPast = s.SessionDate.Date < DateTime.UtcNow.Date || (s.SessionDate.Date == DateTime.UtcNow.Date && s.EndTime < DateTime.UtcNow.TimeOfDay);
                        var isNow = !isPast && s.SessionDate.Date == DateTime.UtcNow.Date && s.StartTime <= DateTime.UtcNow.TimeOfDay && s.EndTime >= DateTime.UtcNow.TimeOfDay;
                        
                        <tr class="hover:bg-surface-container transition-colors group @(s.IsCanceled ? "opacity-60 bg-surface-container-low" : "")">
                            <td class="px-6 py-4">
                                <p class="font-label-md text-label-md text-on-surface">@s.SessionDate.ToString("MMM dd, yyyy")</p>
                                <p class="text-body-sm text-outline">@DateTime.Today.Add(s.StartTime).ToString("hh:mm tt") - @DateTime.Today.Add(s.EndTime).ToString("hh:mm tt")</p>
                            </td>
                            <td class="px-6 py-4">
                                <p class="font-label-md text-label-md text-on-surface">@s.GroupName</p>
                                <p class="text-body-sm text-outline">@s.CourseName</p>
                            </td>
                            <td class="px-6 py-4 text-body-sm text-on-surface-variant">@s.InstructorName</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-label-sm font-label-sm bg-primary-container text-white">@s.AttendanceCount Present</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (s.IsCanceled)
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-error">
                                        <span class="material-symbols-outlined text-[14px]">cancel</span>
                                        Canceled
                                    </span>
                                }
                                else if (isNow)
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-primary">
                                        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-ping"></span>
                                        In Progress
                                    </span>
                                }
                                else if (isPast)
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-outline">
                                        <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                        Completed
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-tertiary">
                                        <span class="material-symbols-outlined text-[14px]">schedule</span>
                                        Upcoming
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="Detail" asp-route-id="@s.Id" class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-outline-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors text-on-surface">
                                    <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <span class="material-symbols-outlined text-outline text-4xl mb-2 block">calendar_month</span>
                            <p class="text-headline-sm font-headline-sm text-on-surface">No sessions found</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
