@model CenterManagement.Web.ViewModels.Student.UpdateStudentViewModel

@{
    ViewData["Title"] = "Edit Student";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-gutter">
        <div class="flex items-center gap-4">
            <a href="javascript:history.back()"
               class="p-2 hover:bg-surface-container-low rounded-full transition-colors">
                <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
            </a>
            <h2 class="font-headline-md text-headline-md text-on-surface">Edit Student</h2>
        </div>
    </div>

    <!-- Validation Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-6 p-4 bg-error-container border border-error/30 rounded-xl">
            <div asp-validation-summary="All" class="text-on-error-container text-body-sm"></div>
        </div>
    }

    <form asp-action="EditPost" asp-route-id="@Model.StudentProfileId" method="post" enctype="multipart/form-data"
          class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentProfileId" />

        <div class="p-8 space-y-8">
            <!-- Student Photo -->
            <section class="flex flex-col items-center space-y-2">
                <div class="relative group cursor-pointer" onclick="document.getElementById('photo-input').click();">
                    <div class="w-24 h-24 rounded-full bg-surface-container-high border-2 border-dashed border-outline-variant flex items-center justify-center overflow-hidden hover:border-primary transition-colors">
                        @if (Model.CurrentImagePath != null)
                        {
                            <img class="w-full h-full object-cover" id="photo-preview" src="/@Model.CurrentImagePath" />
                            <span class="material-symbols-outlined text-outline text-3xl group-hover:text-primary transition-colors hidden" id="photo-icon">add_a_photo</span>
                        }
                        else
                        {
                            <img class="hidden w-full h-full object-cover" id="photo-preview" />
                            <span class="material-symbols-outlined text-outline text-3xl group-hover:text-primary transition-colors" id="photo-icon">add_a_photo</span>
                        }
                    </div>
                    <div class="absolute bottom-0 right-0 bg-primary-container p-1.5 rounded-full text-white shadow-md">
                        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">edit</span>
                    </div>
                </div>
                <p class="font-label-sm text-label-sm text-outline">Change Photo</p>
                <input type="file" asp-for="Photo" id="photo-input" class="hidden" accept="image/png,image/jpeg,image/webp" />
            </section>

            <!-- Personal Information -->
            <div class="space-y-4">
                <h2 class="font-label-md text-label-md text-primary uppercase tracking-wider">Personal Information</h2>

                <div class="space-y-1">
                    <label asp-for="FullName" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Full Name</label>
                    <input asp-for="FullName"
                           class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none"
                           placeholder="Enter student's full name" />
                    <span asp-validation-for="FullName" class="text-error text-label-sm"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="PhoneNumber" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Student Phone Number</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">call</span>
                        <input asp-for="PhoneNumber"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none"
                               placeholder="+1 (555) 000-0000" />
                    </div>
                </div>

                <div class="space-y-1">
                    <label asp-for="ParentPhone" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Parent Phone Number</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">family_restroom</span>
                        <input asp-for="ParentPhone"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none"
                               placeholder="+1 (555) 000-0000" />
                    </div>
                    <span asp-validation-for="ParentPhone" class="text-error text-label-sm"></span>
                </div>
            </div>

            <!-- Academic Details -->
            <div class="space-y-4">
                <h2 class="font-label-md text-label-md text-primary uppercase tracking-wider">Academic Details</h2>

                <div class="space-y-1">
                    <label asp-for="GradeLevelId" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Grade Level</label>
                    <div class="relative">
                        <select asp-for="GradeLevelId"
                                asp-items="Model.GradeLevelSelectList"
                                class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md appearance-none focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none">
                            <option disabled value="">Select Grade</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                    </div>
                    <span asp-validation-for="GradeLevelId" class="text-error text-label-sm"></span>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="p-6 bg-surface border-t border-outline-variant grid grid-cols-2 gap-4">
            <button type="button" onclick="history.back()"
                    class="w-full py-3.5 rounded-lg border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors active:scale-95 duration-150">
                Cancel
            </button>
            <button type="submit"
                    class="w-full py-3.5 rounded-lg bg-primary-container text-white font-label-md shadow-md hover:brightness-110 transition-all active:scale-95 duration-150">
                Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.getElementById('photo-input').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(ev) {
                const preview = document.getElementById('photo-preview');
                const icon = document.getElementById('photo-icon');
                preview.src = ev.target.result;
                preview.classList.remove('hidden');
                if (icon) icon.classList.add('hidden');
            };
            reader.readAsDataURL(file);
        }
    });
</script>
}
