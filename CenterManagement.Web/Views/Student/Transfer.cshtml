@model CenterManagement.Web.ViewModels.Student.TransferStudentViewModel

@{
    ViewData["Title"] = "Transfer Student";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<div class="max-w-xl mx-auto">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-gutter">
        <a href="javascript:history.back()"
           class="p-2 hover:bg-surface-container-low rounded-full transition-colors">
            <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
        </a>
        <h2 class="font-headline-md text-headline-md text-on-surface">Transfer Student</h2>
    </div>

    <!-- Validation Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-6 p-4 bg-error-container border border-error/30 rounded-xl">
            <div asp-validation-summary="All" class="text-on-error-container text-body-sm"></div>
        </div>
    }

    <form asp-action="TransferPost" method="post"
          class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentProfileId" />
        <input type="hidden" asp-for="FromGroupId" />
        <input type="hidden" asp-for="StudentName" />
        <input type="hidden" asp-for="FromGroupName" />

        <div class="p-8 space-y-6">
            <!-- Student Info -->
            <div class="flex items-center gap-4 p-4 bg-surface rounded-lg border border-outline-variant">
                <div class="w-12 h-12 bg-primary-container/10 text-primary rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined">person</span>
                </div>
                <div>
                    <p class="text-label-md font-label-md text-on-surface">@Model.StudentName</p>
                    <p class="text-label-sm font-label-sm text-outline">Student to transfer</p>
                </div>
            </div>

            <!-- From Group (Read-only) -->
            <div class="space-y-1">
                <label class="font-label-sm text-label-sm text-on-surface-variant ml-1">Current Group</label>
                <div class="flex items-center gap-3 p-4 bg-surface-container-low rounded-lg border border-outline-variant">
                    <span class="material-symbols-outlined text-outline">group</span>
                    <span class="text-body-md text-on-surface">@Model.FromGroupName</span>
                    <span class="ml-auto px-2 py-1 rounded-full text-label-sm font-label-sm bg-tertiary-fixed text-tertiary-container">Current</span>
                </div>
            </div>

            <!-- Transfer Arrow -->
            <div class="flex justify-center">
                <div class="p-3 bg-primary/10 text-primary rounded-full">
                    <span class="material-symbols-outlined text-2xl">arrow_downward</span>
                </div>
            </div>

            <!-- To Group -->
            <div class="space-y-1">
                <label asp-for="ToGroupId" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Transfer To</label>
                <div class="relative">
                    <select asp-for="ToGroupId"
                            asp-items="Model.AvailableGroupsSelectList"
                            class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md appearance-none focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none">
                        <option disabled selected value="">Select target group</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                </div>
                <span asp-validation-for="ToGroupId" class="text-error text-label-sm"></span>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="p-6 bg-surface border-t border-outline-variant grid grid-cols-2 gap-4">
            <button type="button" onclick="history.back()"
                    class="w-full py-3.5 rounded-lg border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors active:scale-95 duration-150">
                Cancel
            </button>
            <button type="submit"
                    class="w-full py-3.5 rounded-lg bg-primary-container text-white font-label-md shadow-md hover:brightness-110 transition-all active:scale-95 duration-150">
                Confirm Transfer
            </button>
        </div>
    </form>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
