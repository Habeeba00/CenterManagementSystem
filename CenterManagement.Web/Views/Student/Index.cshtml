@model CenterManagement.Web.ViewModels.Student.StudentListViewModel

@{
    ViewData["Title"] = "Students Directory";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }
</style>

<!-- Page Header Actions -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-stack-md mb-gutter">
    <div class="space-y-1">
        <h3 class="font-headline-md text-headline-md text-on-surface">Manage Students</h3>
        <p class="text-body-sm text-outline">Manage enrollment, track attendance, and handle student records.</p>
    </div>
    <div class="flex items-center gap-3">
        <a asp-action="Create"
           class="flex items-center gap-2 px-5 py-2.5 bg-primary-container text-white font-label-md text-label-md rounded-lg shadow-md hover:opacity-90 transition-all active:scale-95">
            <span class="material-symbols-outlined text-[20px]">add</span>
            New Student
        </a>
    </div>
</div>

<!-- Advanced Filter Bar -->
<form method="get" asp-action="Index" class="bg-surface-container-lowest p-stack-md rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant flex flex-wrap gap-4 items-end mb-gutter">
    <div class="flex-1 min-w-[280px]">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Search Student</label>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
            <input asp-for="SearchQuery"
                   name="SearchQuery"
                   class="w-full pl-10 pr-4 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm transition-all outline-none"
                   placeholder="Search by name or phone..." />
        </div>
    </div>
    <div class="w-48">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Grade</label>
        <select asp-for="GradeLevelId"
                asp-items="Model.GradeLevelSelectList"
                name="GradeLevelId"
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm outline-none">
            <option value="">All Grades</option>
        </select>
    </div>
    <div class="w-48">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Subject</label>
        <select asp-for="SubjectId"
                asp-items="Model.SubjectSelectList"
                name="SubjectId"
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm outline-none">
            <option value="">All Subjects</option>
        </select>
    </div>
    <div class="w-48">
        <label class="block font-label-sm text-label-sm text-outline mb-1.5 ml-1">Payment</label>
        <select asp-for="PaymentStatusFilter"
                name="PaymentStatus"
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary text-body-sm outline-none">
            <option value="">All</option>
            <option value="Paid" selected="@(Model.PaymentStatusFilter == "Paid")">Paid</option>
            <option value="Partial" selected="@(Model.PaymentStatusFilter == "Partial")">Partial</option>
            <option value="Unpaid" selected="@(Model.PaymentStatusFilter == "Unpaid")">Unpaid</option>
        </select>
    </div>
    <button type="submit" class="h-10 px-4 bg-surface-container hover:bg-surface-container-high text-on-surface-variant rounded-lg transition-colors">
        <span class="material-symbols-outlined">filter_list</span>
    </button>
</form>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-4 p-4 bg-error-container border border-error text-on-error-container rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-error">error</span>
        @TempData["Error"]
    </div>
}

<!-- Data Table Card -->
<div class="bg-surface-container-lowest rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant mb-gutter">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant">
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Student Name</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Grade</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Attendance %</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Payment Status</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Parent Phone</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (Model.Students.Any())
                {
                    @foreach (var s in Model.Students)
                    {
                        <tr class="hover:bg-surface-container transition-colors group" id="student-row-@s.StudentProfileId">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 rounded-full overflow-hidden bg-secondary-container flex-shrink-0">
                                        <img alt="@s.FullName"
                                             class="w-full h-full object-cover"
                                             src="@(s.ImagePath != null ? $"/{s.ImagePath}" : "/images/avatar-default.png")" />
                                    </div>
                                    <div>
                                        <p class="font-label-md text-label-md text-on-surface">@s.FullName</p>
                                        <p class="text-body-sm text-outline">@(s.PhoneNumber ?? "—")</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-body-sm text-on-surface-variant">@s.GradeLevelName</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="flex-1 h-1.5 w-16 bg-surface-container-high rounded-full overflow-hidden">
                                        @{
                                            var barColor = s.AttendanceRatePercent >= 80 ? "bg-primary" : (s.AttendanceRatePercent >= 60 ? "bg-tertiary" : "bg-error");
                                        }
                                        <div class="@barColor h-full" style="width: @(s.AttendanceRatePercent)%"></div>
                                    </div>
                                    @{
                                        var textColor = s.AttendanceRatePercent >= 80 ? "text-primary" : (s.AttendanceRatePercent >= 60 ? "text-tertiary" : "text-error");
                                    }
                                    <span class="text-label-sm font-label-sm @textColor">@(s.AttendanceRatePercent)%</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @{
                                    var (pillBg, pillText) = s.PaymentStatus switch
                                    {
                                        "Paid" => ("bg-green-100", "text-green-700"),
                                        "Partial" => ("bg-orange-100", "text-orange-700"),
                                        _ => ("bg-error-container", "text-error")
                                    };
                                }
                                <span class="px-2 py-1 rounded-full text-label-sm font-label-sm @pillBg @pillText">@s.PaymentStatus</span>
                            </td>
                            <td class="px-6 py-4 text-body-sm text-on-surface-variant font-mono">@s.ParentPhone</td>
                            <td class="px-6 py-4">
                                @if (s.IsActive)
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-primary" id="status-@s.StudentProfileId">
                                        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-outline" id="status-@s.StudentProfileId">
                                        <span class="h-1.5 w-1.5 rounded-full bg-outline"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="relative inline-block">
                                    <button class="p-2 rounded-lg hover:bg-surface-container-high text-outline group-hover:text-on-surface transition-all action-menu-btn"
                                            data-student-id="@s.StudentProfileId">
                                        <span class="material-symbols-outlined">more_vert</span>
                                    </button>
                                    <div class="hidden absolute right-0 top-full mt-1 w-48 bg-surface-container-lowest border border-outline-variant shadow-lg rounded-xl z-50 py-2 action-dropdown"
                                         id="dropdown-@s.StudentProfileId">
                                        <a asp-action="Profile" asp-route-id="@s.StudentProfileId"
                                           class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">visibility</span> View Profile
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@s.StudentProfileId"
                                           class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">edit</span> Edit Student
                                        </a>
                                        <a asp-action="Transfer" asp-route-id="@s.StudentProfileId"
                                           class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">swap_horiz</span> Transfer
                                        </a>
                                        <button type="button"
                                                class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2"
                                                onclick="toggleActive(@s.StudentProfileId)">
                                            <span class="material-symbols-outlined text-sm">toggle_on</span> Toggle Active
                                        </button>
                                        <div class="h-[1px] bg-outline-variant my-1"></div>
                                        <form asp-action="Delete" asp-route-id="@s.StudentProfileId" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="w-full text-left px-4 py-2 text-body-sm text-error hover:bg-error-container/20 transition-colors flex items-center gap-2"
                                                    onclick="return confirm('Are you sure you want to archive this student?');">
                                                <span class="material-symbols-outlined text-sm">archive</span> Archive
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center">
                            <span class="material-symbols-outlined text-outline text-4xl mb-2 block">group_off</span>
                            <p class="text-headline-sm font-headline-sm text-on-surface">No students found</p>
                            <p class="text-body-sm text-outline mt-1">Try adjusting your filters or add a new student.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Footer -->
    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-body-sm text-outline">
                Showing @((Model.Page - 1) * Model.PageSize + 1) to @(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount students
            </p>
            <div class="flex items-center gap-1">
                @if (Model.Page > 1)
                {
                    <a asp-action="Index"
                       asp-route-Page="@(Model.Page - 1)"
                       asp-route-SearchQuery="@Model.SearchQuery"
                       asp-route-GradeLevelId="@Model.GradeLevelId"
                       asp-route-SubjectId="@Model.SubjectId"
                       asp-route-PaymentStatus="@Model.PaymentStatusFilter"
                       class="p-2 text-outline hover:text-on-surface hover:bg-surface-container transition-all rounded-lg">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                }
                else
                {
                    <span class="p-2 text-outline opacity-30 rounded-lg">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </span>
                }

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    if (p == Model.Page)
                    {
                        <span class="w-8 h-8 rounded-lg bg-primary-container text-white font-label-sm text-label-sm flex items-center justify-center">@p</span>
                    }
                    else if (p <= 3 || p >= Model.TotalPages - 1 || Math.Abs(p - Model.Page) <= 1)
                    {
                        <a asp-action="Index"
                           asp-route-Page="@p"
                           asp-route-SearchQuery="@Model.SearchQuery"
                           asp-route-GradeLevelId="@Model.GradeLevelId"
                           asp-route-SubjectId="@Model.SubjectId"
                           asp-route-PaymentStatus="@Model.PaymentStatusFilter"
                           class="w-8 h-8 rounded-lg text-outline hover:bg-surface-container font-label-sm text-label-sm flex items-center justify-center">@p</a>
                    }
                    else if (p == 4 || p == Model.TotalPages - 2)
                    {
                        <span class="px-2 text-outline">...</span>
                    }
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a asp-action="Index"
                       asp-route-Page="@(Model.Page + 1)"
                       asp-route-SearchQuery="@Model.SearchQuery"
                       asp-route-GradeLevelId="@Model.GradeLevelId"
                       asp-route-SubjectId="@Model.SubjectId"
                       asp-route-PaymentStatus="@Model.PaymentStatusFilter"
                       class="p-2 text-outline hover:text-on-surface hover:bg-surface-container transition-all rounded-lg">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                }
                else
                {
                    <span class="p-2 text-outline opacity-30 rounded-lg">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </span>
                }
            </div>
        </div>
    }
</div>

<!-- Dashboard Stats Preview -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-gutter">
    <div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex items-center gap-4">
        <div class="p-3 bg-primary/10 text-primary rounded-xl">
            <span class="material-symbols-outlined text-[32px]">group_add</span>
        </div>
        <div>
            <p class="text-label-sm text-outline font-label-sm">Total Students</p>
            <h4 class="text-headline-sm font-headline-sm">@Model.TotalCount</h4>
        </div>
    </div>
    <div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex items-center gap-4">
        <div class="p-3 bg-tertiary/10 text-tertiary rounded-xl">
            <span class="material-symbols-outlined text-[32px]">person_off</span>
        </div>
        <div>
            <p class="text-label-sm text-outline font-label-sm">On This Page</p>
            <h4 class="text-headline-sm font-headline-sm">@Model.Students.Count</h4>
        </div>
    </div>
    <div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex items-center gap-4">
        <div class="p-3 bg-green-100 text-green-700 rounded-xl">
            <span class="material-symbols-outlined text-[32px]">account_balance_wallet</span>
        </div>
        <div>
            <p class="text-label-sm text-outline font-label-sm">Current Page</p>
            <h4 class="text-headline-sm font-headline-sm">Page @Model.Page of @Model.TotalPages</h4>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Action menu toggle
    document.querySelectorAll('.action-menu-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const id = btn.dataset.studentId;
            const dropdown = document.getElementById('dropdown-' + id);

            // Close all other dropdowns
            document.querySelectorAll('.action-dropdown').forEach(d => {
                if (d !== dropdown) d.classList.add('hidden');
            });

            dropdown.classList.toggle('hidden');
        });
    });

    // Close dropdowns on click outside
    document.addEventListener('click', () => {
        document.querySelectorAll('.action-dropdown').forEach(d => d.classList.add('hidden'));
    });

    // Toggle active via fetch
    async function toggleActive(id) {
        try {
            const response = await fetch('/Student/ToggleActive/' + id, { method: 'POST' });
            const data = await response.json();

            if (data.success) {
                const statusEl = document.getElementById('status-' + id);
                if (data.isActive) {
                    statusEl.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Active';
                    statusEl.className = 'flex items-center gap-1.5 text-label-sm font-label-sm text-primary';
                } else {
                    statusEl.innerHTML = '<span class="h-1.5 w-1.5 rounded-full bg-outline"></span> Inactive';
                    statusEl.className = 'flex items-center gap-1.5 text-label-sm font-label-sm text-outline';
                }
            } else {
                alert('Error: ' + data.error);
            }
        } catch (err) {
            alert('Failed to toggle status.');
        }

        // Close dropdown
        document.querySelectorAll('.action-dropdown').forEach(d => d.classList.add('hidden'));
    }

    // Row hover micro-animation
    document.querySelectorAll('tbody tr').forEach(row => {
        row.addEventListener('mouseenter', () => {
            row.style.transform = 'translateX(4px)';
            row.style.transition = 'all 0.2s ease-out';
        });
        row.addEventListener('mouseleave', () => {
            row.style.transform = 'translateX(0px)';
        });
    });
</script>
}
