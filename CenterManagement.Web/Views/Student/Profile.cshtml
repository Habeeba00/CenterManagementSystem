@model CenterManagement.Application.DTOs.Student.StudentProfileDto

@{
    ViewData["Title"] = $"{Model.FullName} — Profile";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .active-tab-indicator {
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 2px;
        background-color: #004ac6;
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .tab-section { display: none; }
    .tab-section.active { display: block; }
</style>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-4 p-4 bg-error-container border border-error text-on-error-container rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-error">error</span>
        @TempData["Error"]
    </div>
}

<!-- Profile Header Section -->
<section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant mb-gutter flex flex-col md:flex-row gap-8 items-start">
    <div class="relative">
        <img alt="@Model.FullName"
             class="w-32 h-32 md:w-40 md:h-40 rounded-xl object-cover border-4 border-surface shadow-md"
             src="@(Model.ImagePath != null ? $"/{Model.ImagePath}" : "/images/avatar-default.png")" />
        <a asp-action="Edit" asp-route-id="@Model.StudentProfileId"
           class="absolute -bottom-2 -right-2 bg-primary text-white p-2 rounded-lg shadow-lg hover:opacity-90 transition-all">
            <span class="material-symbols-outlined text-sm">edit</span>
        </a>
    </div>
    <div class="flex-1 space-y-4">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h2 class="text-headline-lg font-headline-lg text-on-surface">@Model.FullName</h2>
                <div class="flex items-center gap-3 mt-1">
                    <span class="text-label-md font-label-md text-outline">@Model.Email</span>
                    <span class="w-1 h-1 bg-outline rounded-full"></span>
                    <span class="text-label-md font-label-md text-outline">@Model.GradeLevelName</span>
                </div>
            </div>
            <div class="flex items-center gap-3">
                @if (Model.IsActive)
                {
                    <span class="px-4 py-1.5 rounded-full bg-green-100 text-green-700 text-label-md font-label-md flex items-center gap-2" id="profile-status">
                        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                        Active
                    </span>
                }
                else
                {
                    <span class="px-4 py-1.5 rounded-full bg-gray-100 text-gray-600 text-label-md font-label-md flex items-center gap-2" id="profile-status">
                        <span class="w-2 h-2 bg-gray-400 rounded-full"></span>
                        Inactive
                    </span>
                }
                <a asp-action="Edit" asp-route-id="@Model.StudentProfileId"
                   class="bg-primary-container text-white px-6 py-2.5 rounded-lg font-label-md text-label-md hover:opacity-90 transition-all active:scale-95">
                    Edit Profile
                </a>
            </div>
        </div>
        <!-- Quick Stats Grid -->
        @{
            var totalAttendances = Model.RecentAttendances.Count;
            var presentCount = Model.RecentAttendances.Count(a => a.IsPresent);
            var missedCount = Model.RecentAttendances.Count(a => !a.IsPresent);
            var lateCount = Model.RecentAttendances.Count(a => a.IsLate);
        }
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
            <div class="bg-surface p-4 rounded-lg border border-outline-variant">
                <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider">Attendance %</p>
                <p class="text-headline-sm font-headline-sm text-primary mt-1">@(Model.AttendanceRatePercent)%</p>
            </div>
            <div class="bg-surface p-4 rounded-lg border border-outline-variant">
                <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider">Total Enrollments</p>
                <p class="text-headline-sm font-headline-sm text-on-surface mt-1">@Model.Enrollments.Count</p>
            </div>
            <div class="bg-surface p-4 rounded-lg border border-outline-variant">
                <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider">Missed Sessions</p>
                <p class="text-headline-sm font-headline-sm text-error mt-1">@missedCount</p>
            </div>
            <div class="bg-surface p-4 rounded-lg border border-outline-variant">
                <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider">Late Sessions</p>
                <p class="text-headline-sm font-headline-sm text-tertiary mt-1">@lateCount</p>
            </div>
        </div>
    </div>
</section>

<!-- Tabbed Navigation -->
<div class="mb-gutter border-b border-outline-variant overflow-x-auto scrollbar-hide">
    <nav class="flex gap-8 min-w-max" id="profile-tabs">
        <button class="tab-btn pb-4 text-label-md font-label-md text-on-surface relative" onclick="switchTab('personal')">
            Personal Information
            <div class="active-tab-indicator" id="indicator-personal"></div>
        </button>
        <button class="tab-btn pb-4 text-label-md font-label-md text-outline relative hover:text-primary transition-colors" onclick="switchTab('subjects')">
            Enrolled Subjects
            <div class="active-tab-indicator hidden" id="indicator-subjects"></div>
        </button>
        <button class="tab-btn pb-4 text-label-md font-label-md text-outline relative hover:text-primary transition-colors" onclick="switchTab('attendance')">
            Attendance History
            <div class="active-tab-indicator hidden" id="indicator-attendance"></div>
        </button>
        <button class="tab-btn pb-4 text-label-md font-label-md text-outline relative hover:text-primary transition-colors" onclick="switchTab('payments')">
            Payments
            <div class="active-tab-indicator hidden" id="indicator-payments"></div>
        </button>
        <button class="tab-btn pb-4 text-label-md font-label-md text-outline relative hover:text-primary transition-colors" onclick="switchTab('notes')">
            Notes
            <div class="active-tab-indicator hidden" id="indicator-notes"></div>
        </button>
        <button class="tab-btn pb-4 text-label-md font-label-md text-outline relative hover:text-primary transition-colors" onclick="switchTab('sessions')">
            Sessions
            <div class="active-tab-indicator hidden" id="indicator-sessions"></div>
        </button>
    </nav>
</div>

<!-- Tab Content Areas -->
<div id="tab-content">
    <!-- =============================== -->
    <!-- Personal Information Tab -->
    <!-- =============================== -->
    <div class="tab-section active" id="section-personal">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            <div class="lg:col-span-2 space-y-gutter">
                <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-6">Contact Details</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Full Name</p>
                            <p class="text-body-md text-on-surface">@Model.FullName</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Email</p>
                            <p class="text-body-md text-on-surface">@Model.Email</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Phone</p>
                            <p class="text-body-md text-on-surface">@(Model.PhoneNumber ?? "—")</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Parent Phone</p>
                            <p class="text-body-md text-on-surface">@Model.ParentPhone</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Grade Level</p>
                            <p class="text-body-md text-on-surface">@Model.GradeLevelName</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline uppercase tracking-wider mb-1">Join Date</p>
                            <p class="text-body-md text-on-surface">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                    <div class="mt-6 pt-6 border-t border-outline-variant flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-label-md font-label-md text-on-surface">Active Status:</span>
                            <span class="px-3 py-1 rounded-full text-label-sm font-label-sm @(Model.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")" id="personal-status-badge">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                        <button type="button"
                                class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-lg text-label-md font-label-md hover:bg-surface-container-low transition-colors"
                                onclick="toggleProfileActive(@Model.StudentProfileId)">
                            Toggle Active
                        </button>
                    </div>
                </div>
            </div>
            <!-- Right Sidebar -->
            <div class="space-y-gutter">
                <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        <a asp-action="Edit" asp-route-id="@Model.StudentProfileId"
                           class="w-full py-3 border border-outline-variant text-on-surface rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">edit</span> Edit Profile
                        </a>
                        @if (Model.Enrollments.Any(e => e.IsActive))
                        {
                            <a asp-action="Transfer" asp-route-id="@Model.StudentProfileId"
                               class="w-full py-3 border border-primary text-primary rounded-lg font-label-md text-label-md hover:bg-primary/5 transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm">swap_horiz</span> Transfer Group
                            </a>
                        }
                        <form asp-action="Delete" asp-route-id="@Model.StudentProfileId" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="w-full py-3 border border-error text-error rounded-lg font-label-md text-label-md hover:bg-error-container/20 transition-colors flex items-center justify-center gap-2"
                                    onclick="return confirm('Archive this student?');">
                                <span class="material-symbols-outlined text-sm">archive</span> Archive Student
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- =============================== -->
    <!-- Enrolled Subjects Tab -->
    <!-- =============================== -->
    <div class="tab-section" id="section-subjects">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
            <h3 class="text-headline-sm font-headline-sm text-on-surface mb-6">Enrolled Subjects</h3>
            @if (Model.Enrollments.Any())
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @foreach (var e in Model.Enrollments)
                    {
                        <div class="p-4 rounded-lg bg-surface border border-outline-variant flex items-center gap-4">
                            <div class="w-12 h-12 @(e.IsActive ? "bg-primary-container/10 text-primary" : "bg-gray-100 text-gray-400") rounded-lg flex items-center justify-center">
                                <span class="material-symbols-outlined">school</span>
                            </div>
                            <div class="flex-1">
                                <p class="text-label-md font-label-md text-on-surface">@e.CourseName</p>
                                <p class="text-label-sm font-label-sm text-outline">@e.InstructorName • @e.GroupName</p>
                            </div>
                            <div>
                                @if (e.IsActive)
                                {
                                    <span class="px-2 py-1 rounded-full text-label-sm font-label-sm bg-green-100 text-green-700">Active</span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 rounded-full text-label-sm font-label-sm bg-gray-100 text-gray-500">Inactive</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="p-12 text-center border border-dashed border-outline-variant rounded-lg">
                    <span class="material-symbols-outlined text-outline text-4xl mb-2">school</span>
                    <p class="text-headline-sm font-headline-sm text-on-surface">No Enrollments</p>
                    <p class="text-body-sm text-outline mt-1">This student has no group enrollments yet.</p>
                </div>
            }
        </div>
    </div>

    <!-- =============================== -->
    <!-- Attendance History Tab -->
    <!-- =============================== -->
    <div class="tab-section" id="section-attendance">
        <div class="bg-white rounded-xl shadow-sm border border-outline-variant overflow-hidden">
            <div class="px-6 py-4 border-b border-outline-variant bg-surface-container-low">
                <h3 class="text-headline-sm font-headline-sm text-on-surface">Recent Attendance (Last 10)</h3>
            </div>
            @if (Model.RecentAttendances.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-surface-container-high border-b border-outline-variant">
                            <tr>
                                <th class="px-6 py-3 text-label-sm font-label-sm text-outline uppercase">Date</th>
                                <th class="px-6 py-3 text-label-sm font-label-sm text-outline uppercase">Subject</th>
                                <th class="px-6 py-3 text-label-sm font-label-sm text-outline uppercase">Group</th>
                                <th class="px-6 py-3 text-label-sm font-label-sm text-outline uppercase">Time In</th>
                                <th class="px-6 py-3 text-label-sm font-label-sm text-outline uppercase">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant">
                            @foreach (var a in Model.RecentAttendances)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors">
                                    <td class="px-6 py-4 text-body-sm text-on-surface">@a.SessionDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4 text-body-sm text-on-surface">@a.SubjectName</td>
                                    <td class="px-6 py-4 text-body-sm text-on-surface">@a.GroupName</td>
                                    <td class="px-6 py-4 text-body-sm text-on-surface">@a.ScanTime.ToString("hh:mm tt")</td>
                                    <td class="px-6 py-4">
                                        @if (a.IsPresent && !a.IsLate)
                                        {
                                            <span class="px-2 py-1 rounded text-xs font-label-sm bg-green-50 text-green-700">Present</span>
                                        }
                                        else if (a.IsLate)
                                        {
                                            <span class="px-2 py-1 rounded text-xs font-label-sm bg-tertiary-fixed text-tertiary-container">Late</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 rounded text-xs font-label-sm bg-error-container text-error">Absent</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-outline text-4xl mb-2">event_busy</span>
                    <p class="text-headline-sm font-headline-sm text-on-surface">No Attendance Records</p>
                    <p class="text-body-sm text-outline mt-1">Attendance data will appear once sessions are tracked.</p>
                </div>
            }
        </div>
    </div>

    <!-- =============================== -->
    <!-- Payments Tab -->
    <!-- =============================== -->
    <div class="tab-section" id="section-payments">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            <div class="lg:col-span-2">
                <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-6">Course Payments</h3>
                    @if (Model.CoursePayments.Any())
                    {
                        <div class="space-y-4">
                            @foreach (var cp in Model.CoursePayments)
                            {
                                <div class="p-4 rounded-lg border border-outline-variant bg-surface flex items-center justify-between">
                                    <div>
                                        <p class="text-label-md font-label-md text-on-surface">@cp.CourseName</p>
                                        <p class="text-label-sm font-label-sm text-outline">
                                            Paid: @cp.PaidAmount.ToString("C") / @cp.RequiredAmount.ToString("C")
                                        </p>
                                    </div>
                                    <div class="text-right">
                                        @if (cp.IsPaid)
                                        {
                                            <span class="px-3 py-1 rounded-full text-label-sm font-label-sm bg-green-100 text-green-700">Paid</span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 rounded-full text-label-sm font-label-sm bg-error-container text-error">
                                                Remaining: @cp.RemainingAmount.ToString("C")
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-12 text-center border border-dashed border-outline-variant rounded-lg">
                            <span class="material-symbols-outlined text-outline text-4xl mb-2">payments</span>
                            <p class="text-headline-sm font-headline-sm text-on-surface">No Payment Records</p>
                            <p class="text-body-sm text-outline mt-1">Payment data will appear once courses are assigned.</p>
                        </div>
                    }
                </div>
            </div>
            <!-- Financial Summary -->
            <div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-6">Financial Summary</h3>
                    @{
                        var totalRequired = Model.CoursePayments.Sum(p => p.RequiredAmount);
                        var totalPaid = Model.CoursePayments.Sum(p => p.PaidAmount);
                        var totalRemaining = Model.CoursePayments.Sum(p => p.RemainingAmount);
                    }
                    <div class="space-y-3">
                        <div class="flex justify-between text-body-sm">
                            <span class="text-outline">Total Required</span>
                            <span class="text-on-surface font-semibold">@totalRequired.ToString("C")</span>
                        </div>
                        <div class="flex justify-between text-body-sm">
                            <span class="text-outline">Paid to Date</span>
                            <span class="text-green-600 font-semibold">@totalPaid.ToString("C")</span>
                        </div>
                        <div class="flex justify-between text-body-sm border-t border-outline-variant pt-3">
                            <span class="text-outline font-semibold">Remaining</span>
                            <span class="text-error font-semibold">@totalRemaining.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- =============================== -->
    <!-- Notes Tab -->
    <!-- =============================== -->
    <div class="tab-section" id="section-notes">
        <div class="bg-white p-12 rounded-xl text-center border border-dashed border-outline-variant">
            <span class="material-symbols-outlined text-outline text-4xl mb-2">note_alt</span>
            <p class="text-headline-sm font-headline-sm text-on-surface">Notes</p>
            <p class="text-body-sm text-outline mt-1">Notes feature will be available in a future update.</p>
        </div>
    </div>

    <!-- =============================== -->
    <!-- Sessions Tab -->
    <!-- =============================== -->
    <div class="tab-section" id="section-sessions">
        @if (Model.UpcomingSessions.Any())
        {
            <div class="bg-white rounded-xl p-6 shadow-sm border border-outline-variant">
                <h3 class="text-headline-sm font-headline-sm text-on-surface mb-6">Upcoming Sessions</h3>
                @foreach (var session in Model.UpcomingSessions)
                {
                    <div class="p-4 rounded-lg border border-outline-variant bg-surface mb-3">
                        <p class="text-label-md font-label-md">@session.SubjectName — @session.GroupName</p>
                        <p class="text-label-sm text-outline">@session.SessionDate.ToString("MMM dd") • @session.StartTime - @session.EndTime</p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white p-12 rounded-xl text-center border border-dashed border-outline-variant">
                <span class="material-symbols-outlined text-outline text-4xl mb-2">event</span>
                <p class="text-headline-sm font-headline-sm text-on-surface">No Upcoming Sessions</p>
                <p class="text-body-sm text-outline mt-1">Session data will be populated in Phase 3.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function switchTab(tabName) {
        // Update tab button styles
        document.querySelectorAll('.tab-btn').forEach(tab => {
            tab.classList.remove('text-on-surface');
            tab.classList.add('text-outline');
        });
        document.querySelectorAll('.active-tab-indicator').forEach(ind => ind.classList.add('hidden'));

        const activeTab = Array.from(document.querySelectorAll('.tab-btn'))
            .find(t => t.textContent.trim().toLowerCase().includes(tabName.toLowerCase()));
        if (activeTab) {
            activeTab.classList.remove('text-outline');
            activeTab.classList.add('text-on-surface');
            const indicator = activeTab.querySelector('.active-tab-indicator');
            if (indicator) indicator.classList.remove('hidden');
        }

        // Switch content sections
        document.querySelectorAll('.tab-section').forEach(s => s.classList.remove('active'));
        const section = document.getElementById('section-' + tabName);
        if (section) section.classList.add('active');
    }

    // Toggle active from profile
    async function toggleProfileActive(id) {
        try {
            const response = await fetch('/Student/ToggleActive/' + id, { method: 'POST' });
            const data = await response.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Error: ' + data.error);
            }
        } catch (err) {
            alert('Failed to toggle status.');
        }
    }

    // Initialize first tab
    switchTab('personal');
</script>
}
