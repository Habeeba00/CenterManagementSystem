@{
    ViewData["Title"] = "Analytics & Insights";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-headline-lg font-headline-lg text-on-surface">Analytics & Insights</h1>
        <p class="text-body-md text-on-surface-variant mt-1">Data-driven overview of your center's performance.</p>
    </div>
</div>

<!-- Analytics KPI Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-8">
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-primary mb-2">group</span>
        <p class="text-body-sm text-on-surface-variant">Total Students</p>
        <p id="anl-students" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-green-600 mb-2">person_add</span>
        <p class="text-body-sm text-on-surface-variant">New Enrollments</p>
        <p id="anl-enrollments" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-amber-600 mb-2">payments</span>
        <p class="text-body-sm text-on-surface-variant">Monthly Revenue</p>
        <p id="anl-revenue" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-blue-600 mb-2">fact_check</span>
        <p class="text-body-sm text-on-surface-variant">Attendance Rate</p>
        <p id="anl-attendance" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-purple-600 mb-2">school</span>
        <p class="text-body-sm text-on-surface-variant">Instructors</p>
        <p id="anl-instructors" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
    <div class="bg-white border border-outline-variant p-5 rounded-xl card-shadow text-center">
        <span class="material-symbols-outlined text-cyan-600 mb-2">groups</span>
        <p class="text-body-sm text-on-surface-variant">Active Groups</p>
        <p id="anl-groups" class="text-headline-sm font-headline-sm text-on-surface mt-1">—</p>
    </div>
</div>

<!-- Charts Row 1: Attendance Trend + Grade Distribution -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Attendance Trend (2/3 width) -->
    <div class="lg:col-span-2 bg-white border border-outline-variant p-6 rounded-xl card-shadow">
        <h3 class="text-headline-sm font-headline-sm text-on-surface mb-4">Attendance Trend (30 Days)</h3>
        <canvas id="trend-chart" height="120"></canvas>
    </div>
    <!-- Grade Distribution (1/3 width) -->
    <div class="bg-white border border-outline-variant p-6 rounded-xl card-shadow">
        <h3 class="text-headline-sm font-headline-sm text-on-surface mb-4">Student Distribution</h3>
        <canvas id="distribution-chart" height="200"></canvas>
    </div>
</div>

<!-- Charts Row 2: Revenue by Subject + Top Teachers -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Revenue by Subject -->
    <div class="bg-white border border-outline-variant p-6 rounded-xl card-shadow">
        <h3 class="text-headline-sm font-headline-sm text-on-surface mb-4">Revenue by Subject</h3>
        <canvas id="revenue-chart" height="200"></canvas>
    </div>
    <!-- Top Teachers -->
    <div class="bg-white border border-outline-variant p-6 rounded-xl card-shadow">
        <h3 class="text-headline-sm font-headline-sm text-on-surface mb-4">Top Teachers</h3>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-surface-container-low">
                    <tr>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">#</th>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">Name</th>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">Subject</th>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">Groups</th>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">Sessions</th>
                        <th class="px-4 py-2 text-left text-label-sm font-label-sm text-on-surface-variant">Att. Rate</th>
                    </tr>
                </thead>
                <tbody id="top-teachers-tbody" class="divide-y divide-outline-variant"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Smart Insights -->
<div class="mb-8">
    <h2 class="text-headline-sm font-headline-sm text-on-surface mb-4">
        <span class="material-symbols-outlined text-primary align-middle mr-1">lightbulb</span>
        Smart Insights
    </h2>
    <div id="insights-container">
        <div class="text-center py-8 text-on-surface-variant">
            <span class="material-symbols-outlined text-3xl mb-2 block opacity-50">hourglass_top</span>
            <p class="text-body-sm">Analyzing data...</p>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
    let trendChart, distChart, revChart;

    async function loadAnalytics() {
        // KPIs
        try {
            const kpiRes = await fetch('/Analytics/Kpis');
            const kpi = await kpiRes.json();
            document.getElementById('anl-students').textContent = kpi.totalStudents;
            document.getElementById('anl-enrollments').textContent = kpi.newEnrollmentsThisMonth;
            document.getElementById('anl-revenue').textContent = kpi.monthlyRevenue.toFixed(2) + ' EGP';
            document.getElementById('anl-attendance').textContent = kpi.attendanceRatePercent.toFixed(1) + '%';
            document.getElementById('anl-instructors').textContent = kpi.totalInstructors;
            document.getElementById('anl-groups').textContent = kpi.totalGroups;
        } catch (e) { console.error('KPI load error:', e); }

        // Attendance Trend
        try {
            const trendRes = await fetch('/Analytics/AttendanceTrend');
            const trend = await trendRes.json();
            if (trendChart) trendChart.destroy();
            trendChart = new Chart(document.getElementById('trend-chart'), {
                type: 'line',
                data: {
                    labels: trend.map(t => new Date(t.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
                    datasets: [{
                        label: 'Attendance %',
                        data: trend.map(t => t.attendanceRatePercent),
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37,99,235,0.08)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2,
                        pointRadius: 3,
                        pointBackgroundColor: '#2563eb'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { min: 0, max: 100, ticks: { callback: v => v + '%' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        } catch (e) { console.error('Trend chart error:', e); }

        // Grade Distribution
        try {
            const distRes = await fetch('/Analytics/StudentDistribution');
            const dist = await distRes.json();
            if (distChart) distChart.destroy();
            distChart = new Chart(document.getElementById('distribution-chart'), {
                type: 'doughnut',
                data: {
                    labels: dist.map(d => d.gradeLevelName),
                    datasets: [{
                        data: dist.map(d => d.studentCount),
                        backgroundColor: ['#2563eb', '#0891b2', '#7c3aed', '#ea580c', '#16a34a', '#d946ef', '#0284c7', '#dc2626']
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true } }
                    }
                }
            });
        } catch (e) { console.error('Distribution chart error:', e); }

        // Revenue by Subject
        try {
            const revRes = await fetch('/Analytics/RevenueBySubject');
            const rev = await revRes.json();
            if (revChart) revChart.destroy();
            revChart = new Chart(document.getElementById('revenue-chart'), {
                type: 'bar',
                data: {
                    labels: rev.map(r => r.subjectName),
                    datasets: [{
                        label: 'Revenue (EGP)',
                        data: rev.map(r => r.totalRevenue),
                        backgroundColor: '#2563eb',
                        borderRadius: 6,
                        barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true },
                        x: { grid: { display: false } }
                    }
                }
            });
        } catch (e) { console.error('Revenue chart error:', e); }

        // Top Teachers
        try {
            const teachRes = await fetch('/Analytics/TopTeachers');
            const teachers = await teachRes.json();
            const tbody = document.getElementById('top-teachers-tbody');
            if (teachers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-body-sm text-on-surface-variant">No instructor data available.</td></tr>';
            } else {
                tbody.innerHTML = teachers.map((t, i) => `
                    <tr class="hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3 text-body-sm text-on-surface-variant">${i + 1}</td>
                        <td class="px-4 py-3 text-body-sm font-medium text-on-surface">${t.instructorName}</td>
                        <td class="px-4 py-3 text-body-sm text-on-surface-variant">${t.subjectName}</td>
                        <td class="px-4 py-3 text-body-sm text-on-surface-variant">${t.groupCount}</td>
                        <td class="px-4 py-3 text-body-sm text-on-surface-variant">${t.totalSessionsConducted}</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-label-sm font-label-sm
                                ${t.attendanceRatePercent >= 80 ? 'bg-green-100 text-green-700' : t.attendanceRatePercent >= 60 ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-700'}">
                                ${t.attendanceRatePercent.toFixed(1)}%
                            </span>
                        </td>
                    </tr>`
                ).join('');
            }
        } catch (e) { console.error('Top teachers error:', e); }

        // Smart Insights
        try {
            const insRes = await fetch('/Analytics/SmartInsights');
            const insights = await insRes.json();
            const container = document.getElementById('insights-container');
            if (insights.length === 0) {
                container.innerHTML = `
                    <div class="bg-green-50 border border-green-200 p-5 rounded-xl flex items-center gap-3">
                        <span class="material-symbols-outlined text-green-600">check_circle</span>
                        <p class="text-body-sm text-green-800">No insights at this time. All metrics look healthy.</p>
                    </div>`;
            } else {
                container.innerHTML = insights.map(ins => `
                    <div class="p-4 rounded-xl border ${ins.severity === 'Critical'
                        ? 'border-red-300 bg-red-50'
                        : 'border-amber-300 bg-amber-50'} mb-3 flex items-start gap-3">
                        <span class="material-symbols-outlined ${ins.severity === 'Critical' ? 'text-red-600' : 'text-amber-600'} mt-0.5">
                            ${ins.severity === 'Critical' ? 'error' : 'warning'}
                        </span>
                        <div>
                            <p class="font-label-md text-label-md ${ins.severity === 'Critical' ? 'text-red-800' : 'text-amber-800'}">${ins.category}</p>
                            <p class="text-body-sm mt-1 ${ins.severity === 'Critical' ? 'text-red-700' : 'text-amber-700'}">${ins.description}</p>
                        </div>
                    </div>`
                ).join('');
            }
        } catch (e) { console.error('Smart insights error:', e); }
    }

    document.addEventListener('DOMContentLoaded', loadAnalytics);
</script>
}
