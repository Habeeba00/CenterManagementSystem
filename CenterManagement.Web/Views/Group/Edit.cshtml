@model UpdateGroupViewModel

@{
    ViewData["Title"] = "Edit Group";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-gutter">
        <a href="javascript:history.back()" class="p-2 hover:bg-surface-container-low rounded-full transition-colors">
            <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
        </a>
        <h2 class="font-headline-md text-headline-md text-on-surface">Edit Group</h2>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-6 p-4 bg-error-container border border-error/30 rounded-xl">
            <div asp-validation-summary="All" class="text-on-error-container text-body-sm"></div>
        </div>
    }

    <form asp-action="EditPost" method="post" class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        @Html.AntiForgeryToken()
        
        <div class="p-8 space-y-4">
            <div class="space-y-1">
                <label asp-for="Name" class="font-label-sm text-label-sm text-on-surface-variant ml-1">Group Name</label>
                <input asp-for="Name" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-body-md focus:border-primary-container focus:ring-2 focus:ring-primary/10 transition-all outline-none" />
                <span asp-validation-for="Name" class="text-error text-label-sm"></span>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-primary rounded border-outline-variant focus:ring-primary focus:ring-offset-surface-container-lowest transition-colors cursor-pointer" />
                <label asp-for="IsActive" class="font-label-md text-label-md text-on-surface cursor-pointer select-none">Active Group</label>
            </div>
            
            <p class="text-body-sm text-outline mt-4">
                Note: To change the course or instructor, please use the appropriate actions on the group list page.
            </p>
        </div>

        <div class="p-6 bg-surface border-t border-outline-variant grid grid-cols-2 gap-4">
            <button type="button" onclick="history.back()" class="w-full py-3.5 rounded-lg border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors">Cancel</button>
            <button type="submit" class="w-full py-3.5 rounded-lg bg-primary-container text-white font-label-md shadow-md hover:brightness-110 transition-all">Update Group</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
