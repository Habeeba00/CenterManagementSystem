@model List<InstructorListItemDto>

@{
    ViewData["Title"] = "Instructors Directory";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }
</style>

<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-stack-md mb-gutter">
    <div class="space-y-1">
        <h3 class="font-headline-md text-headline-md text-on-surface">Manage Instructors</h3>
        <p class="text-body-sm text-outline">Manage teacher profiles, assign subjects, and track workload.</p>
    </div>
    <div class="flex items-center gap-3">
        <a asp-action="Create" class="flex items-center gap-2 px-5 py-2.5 bg-primary-container text-white font-label-md text-label-md rounded-lg shadow-md hover:opacity-90 transition-all active:scale-95">
            <span class="material-symbols-outlined text-[20px]">person_add</span>
            New Instructor
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-4 p-4 bg-error-container border border-error text-on-error-container rounded-lg text-body-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-error">error</span>
        @TempData["Error"]
    </div>
}

<div class="bg-surface-container-lowest rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant mb-gutter">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant">
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Instructor</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Subject</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Specialization</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Active Groups</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (Model.Any())
                {
                    @foreach (var i in Model)
                    {
                        <tr class="hover:bg-surface-container transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 rounded-full overflow-hidden bg-secondary-container flex-shrink-0">
                                        <img alt="@i.FullName" class="w-full h-full object-cover" src="@(i.ImagePath != null ? $"/{i.ImagePath}" : "/images/avatar-default.png")" />
                                    </div>
                                    <div>
                                        <p class="font-label-md text-label-md text-on-surface">@i.FullName</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-body-sm text-on-surface-variant">@(i.SubjectName ?? "—")</td>
                            <td class="px-6 py-4 text-body-sm text-on-surface-variant">@i.Specialization</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-label-sm font-label-sm bg-primary-container text-white">@i.GroupCount</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (i.IsActive)
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-primary">
                                        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1.5 text-label-sm font-label-sm text-outline">
                                        <span class="h-1.5 w-1.5 rounded-full bg-outline"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="relative inline-block">
                                    <button class="p-2 rounded-lg hover:bg-surface-container-high text-outline group-hover:text-on-surface transition-all action-menu-btn" data-id="@i.InstructorProfileId">
                                        <span class="material-symbols-outlined">more_vert</span>
                                    </button>
                                    <div class="hidden absolute right-0 top-full mt-1 w-48 bg-surface-container-lowest border border-outline-variant shadow-lg rounded-xl z-50 py-2 action-dropdown" id="dropdown-@i.InstructorProfileId">
                                        <a asp-action="Profile" asp-route-id="@i.InstructorProfileId" class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">visibility</span> View Profile
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@i.InstructorProfileId" class="w-full text-left px-4 py-2 text-body-sm hover:bg-surface-container transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-sm">edit</span> Edit Profile
                                        </a>
                                        <div class="h-[1px] bg-outline-variant my-1"></div>
                                        <form asp-action="Delete" asp-route-id="@i.InstructorProfileId" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="w-full text-left px-4 py-2 text-body-sm text-error hover:bg-error-container/20 transition-colors flex items-center gap-2" onclick="return confirm('Archive this instructor?');">
                                                <span class="material-symbols-outlined text-sm">archive</span> Archive
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <span class="material-symbols-outlined text-outline text-4xl mb-2 block">school</span>
                            <p class="text-headline-sm font-headline-sm text-on-surface">No instructors found</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.action-menu-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = btn.dataset.id;
                const dropdown = document.getElementById('dropdown-' + id);
                document.querySelectorAll('.action-dropdown').forEach(d => {
                    if (d !== dropdown) d.classList.add('hidden');
                });
                dropdown.classList.toggle('hidden');
            });
        });
        document.addEventListener('click', () => {
            document.querySelectorAll('.action-dropdown').forEach(d => d.classList.add('hidden'));
        });
    </script>
}
