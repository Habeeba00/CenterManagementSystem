@model InstructorProfileDto

@{
    ViewData["Title"] = "Instructor Profile";
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
    }
</style>

<div class="max-w-7xl mx-auto space-y-gutter">
    <div class="flex items-center gap-4 mb-4">
        <a href="javascript:history.back()" class="flex items-center gap-2 text-primary font-bold active:scale-95 duration-150">
            <span class="material-symbols-outlined">arrow_back</span>
            <span class="font-label-md text-label-md">Back to Directory</span>
        </a>
    </div>

    <!-- Instructor Profile Header -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        <div class="h-32 bg-gradient-to-r from-primary to-primary-container"></div>
        <div class="px-8 pb-8 relative">
            <div class="flex flex-col md:flex-row gap-6 items-start md:items-end -mt-12 mb-6">
                <div class="w-24 h-24 rounded-xl border-4 border-surface-container-lowest bg-surface-container-high overflow-hidden flex-shrink-0 shadow-md">
                    <img alt="@Model.FullName" class="w-full h-full object-cover" src="@(Model.ImagePath != null ? $"/{Model.ImagePath}" : "/images/avatar-default.png")" />
                </div>
                <div class="flex-1 space-y-1">
                    <h2 class="font-headline-md text-headline-md text-on-surface">@Model.FullName</h2>
                    <div class="flex items-center gap-4 text-body-sm text-outline">
                        <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">school</span> @Model.Specialization</span>
                        @if (!string.IsNullOrEmpty(Model.SubjectName))
                        {
                            <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">book</span> @Model.SubjectName</span>
                        }
                    </div>
                </div>
                <div class="flex items-center gap-3 w-full md:w-auto">
                    <a asp-action="Edit" asp-route-id="@Model.InstructorProfileId" class="flex-1 md:flex-none px-4 py-2 bg-surface border border-outline-variant text-on-surface rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors text-center shadow-sm">
                        Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
        <!-- Assigned Groups -->
        <div class="bg-surface-container-lowest rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant overflow-hidden flex flex-col">
            <div class="px-6 py-4 border-b border-outline-variant flex items-center justify-between">
                <h3 class="font-headline-sm text-headline-sm text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">groups</span>
                    Assigned Groups
                </h3>
                <span class="px-2.5 py-1 bg-surface-container-high text-on-surface-variant rounded-full text-label-sm font-label-sm">@Model.Groups.Count Groups</span>
            </div>
            <div class="flex-1 overflow-y-auto max-h-[400px]">
                @if (Model.Groups.Any())
                {
                    <ul class="divide-y divide-outline-variant">
                        @foreach (var g in Model.Groups)
                        {
                            <li class="px-6 py-4 hover:bg-surface-container-low transition-colors">
                                <div class="flex justify-between items-center">
                                    <div>
                                        <p class="font-label-md text-label-md text-on-surface">@g.Name</p>
                                        <p class="text-body-sm text-outline">@g.CourseName</p>
                                    </div>
                                    <span class="px-2 py-1 bg-primary-container text-white rounded-full text-[11px] font-bold">@g.EnrollmentCount Students</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-8 text-center text-outline">
                        <span class="material-symbols-outlined text-3xl mb-2">group_off</span>
                        <p class="text-body-sm">No assigned groups.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Upcoming Sessions -->
        <div class="bg-surface-container-lowest rounded-xl shadow-[0px_1px_3px_rgba(0,0,0,0.1),0px_10px_15px_-3px_rgba(30,41,59,0.05)] border border-outline-variant overflow-hidden flex flex-col">
            <div class="px-6 py-4 border-b border-outline-variant flex items-center justify-between">
                <h3 class="font-headline-sm text-headline-sm text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-tertiary">event</span>
                    Upcoming Sessions
                </h3>
            </div>
            <div class="flex-1 overflow-y-auto max-h-[400px]">
                @if (Model.UpcomingSessions.Any())
                {
                    <ul class="divide-y divide-outline-variant">
                        @foreach (var s in Model.UpcomingSessions)
                        {
                            <li class="px-6 py-4 hover:bg-surface-container-low transition-colors">
                                <div class="flex items-center gap-4">
                                    <div class="text-center p-2 bg-surface-container rounded-lg min-w-[60px]">
                                        <p class="text-label-sm font-label-sm text-primary uppercase">@s.SessionDate.ToString("MMM")</p>
                                        <p class="text-headline-md font-headline-md text-on-surface">@s.SessionDate.ToString("dd")</p>
                                    </div>
                                    <div class="flex-1">
                                        <p class="font-label-md text-label-md text-on-surface">@s.GroupName</p>
                                        <p class="text-body-sm text-outline">
                                            @DateTime.Today.Add(s.StartTime).ToString("hh:mm tt") 
                                            - @s.CourseName
                                        </p>
                                    </div>
                                    <a asp-controller="Session" asp-action="Detail" asp-route-id="@s.Id" class="p-2 text-outline hover:bg-surface-container hover:text-primary rounded-full transition-colors">
                                        <span class="material-symbols-outlined">arrow_forward_ios</span>
                                    </a>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-8 text-center text-outline">
                        <span class="material-symbols-outlined text-3xl mb-2">event_busy</span>
                        <p class="text-body-sm">No upcoming sessions.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
