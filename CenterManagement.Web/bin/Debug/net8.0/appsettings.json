{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=.;Database=CenterManagementSystemDB;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "FileUpload": {
        "MaxFileSizeMb": 5
    },
    "AppSettings": {
        "AttendanceLateGraceMinutes": 15,
        "NotificationPollIntervalSeconds": 60
    }
}
